---
import ThemeHead from "@/components/ThemeHead.astro";
import SEO from "@/components/SEO.astro";
import { PomodoroApp } from "@/components/pomodoro/pomodoro-app";
import "@/styles/globals.css";
---

<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<link rel="preload" as="image" href="/icon-512.png" />
		<!-- iOS Safari 最優先設定 -->
		<link rel="apple-touch-icon" href="/apple-icon.png" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="default" />
		<meta name="apple-mobile-web-app-title" content="Pomodoro Timer" />

		<SEO
			title="Pomodoro Timer | 集中力を最大化するポモドーロ・タイマー"
			description="集中力を最大化するポモドーロ・タイマー。iOS風の美しいデザイン、カスタムテーマ、オフライン対応のPWA。作業を細分化して、圧倒的な生産性を手に入れよう。"
			image="/icon-512.png"
		/>
		<meta name="theme-color" content="#1a1b26" />
		<link rel="icon" type="image/png" href="/favicon.png?v=2" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&family=Zen+Maru+Gothic:wght@400;500;700&display=swap"
			rel="stylesheet"
			media="print"
			onload="this.media='all'"
		/>
		<link rel="manifest" href="/manifest.json" />
		<ThemeHead />
	</head>
	<body>
		<main>
			<div class="sr-only">
				<h1>Pomodoro Timer - スマートに集中するポモドーロ・タイマー</h1>
			</div>

			<PomodoroApp client:only="react" />

			<!-- SEO Content Section - Visible to crawlers and users who scroll down -->
			<footer
				class="mt-20 pb-20 px-6 max-w-4xl mx-auto text-muted-foreground border-t border-border pt-10"
			>
				<section class="grid gap-12">
					<div class="space-y-4">
						<h2 class="text-2xl font-bold text-foreground">
							ポモドーロ・タイマーで集中力を最大化
						</h2>
						<p class="leading-relaxed">
							ポモドーロ・テクニックは、25分の集中作業と5分の短い休憩を繰り返すことで、精神的な疲労を抑え、高い生産性を維持するための時間管理術です。このタイマーは、直感的な操作感と美しいデザインで、あなたの作業効率を強力にサポートします。
						</p>
					</div>

					<div class="grid md:grid-cols-2 gap-8">
						<div class="space-y-4">
							<h3 class="text-xl font-semibold text-foreground">
								主な特徴
							</h3>
							<ul class="list-disc list-inside space-y-2">
								<li>集中時間を自由にカスタマイズ可能</li>
								<li>タスクごとの履歴と統計を確認</li>
								<li>PWA対応によりオフラインでも動作</li>
								<li>洗練されたダークテーマ</li>
							</ul>
						</div>
						<div class="space-y-4">
							<h3 class="text-xl font-semibold text-foreground">
								おすすめの使い方
							</h3>
							<ul class="list-disc list-inside space-y-2">
								<li>1つのタスクに集中して25分間取り組む</li>
								<li>休憩時間は画面から離れてリフレッシュ</li>
								<li>4回のポモドーロごとに長めの休憩を取る</li>
								<li>統計機能で自分の集中パターンを分析</li>
							</ul>
						</div>
					</div>
				</section>
				<p class="mt-20 text-center text-sm">
					&copy; {new Date().getFullYear()} Pomodoro by <a
						href="https://manpuc.me"
						class="hover:underline text-primary">manpuc</a
					>. All rights reserved.
				</p>
			</footer>
		</main>

		<script src="../client.ts"></script>
		<!-- Cloudflare Web Analytics -->
		<script
			defer
			src="https://static.cloudflareinsights.com/beacon.min.js"
			data-cf-beacon='{"token": "c1d318fac0a140d0a8d6734df8ab0770"}'
		></script>
		<!-- End Cloudflare Web Analytics -->
	</body>
</html>
