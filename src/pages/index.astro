---
import ThemeHead from '@/components/ThemeHead.astro';
import { PomodoroApp } from '@/components/pomodoro/pomodoro-app';
import '@/styles/globals.css';
---

<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon.png?v=2" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#1a1b26" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&family=Zen+Maru+Gothic:wght@400;500;700&display=swap" rel="stylesheet">
		<link rel="manifest" href="/manifest.webmanifest?v=2" />
		<title>Pomodoro Timer</title>
		<ThemeHead />
	</head>
	<body>
		<PomodoroApp client:only="react" />

		<script>
		  import '../client';
		</script>
		<!-- Cloudflare Web Analytics -->
		<script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "c1d318fac0a140d0a8d6734df8ab0770"}'></script>
		<!-- End Cloudflare Web Analytics -->
	</body>
</html>
