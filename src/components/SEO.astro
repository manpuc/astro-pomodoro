---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  type?: "website" | "article" | "software";
}

const {
  title = "Pomodoro Timer | Focus & Productivity",
  description = "A minimalist, high-performance Pomodoro timer for focus and productivity. iOS-inspired design with customizable themes and local history.",
  image = "/icon-512.png",
  canonicalURL = Astro.url.href,
  type = "website",
} = Astro.props;

const siteName = "Pomodoro";
const twitterHandle = "@manpuc";
const ogImageURL = new URL(image, Astro.site);
---

<!-- Global Metadata -->
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="title" content={title} />
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type === "software" ? "website" : type} />
<meta property="og:url" content={Astro.url.href} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content="ja_JP" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url.href} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImageURL} />
{twitterHandle && <meta property="twitter:site" content={twitterHandle} />}

<!-- Additional SEO -->
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<meta name="googlebot" content="index, follow" />

<!-- JSON-LD -->
<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "SoftwareApplication",
        "@id": "https://pomodoro.manpuc.me/#software",
        "name": title,
        "description": description,
        "applicationCategory": "ProductivityApplication",
        "operatingSystem": "Web, iOS, Android, Windows, macOS",
        "url": "https://pomodoro.manpuc.me",
        "author": {
          "@type": "Person",
          "@id": "https://manpuc.me/#person",
          "name": "manpuc",
          "url": "https://manpuc.me"
        },
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "JPY"
        },
        "featureList": [
          "Pomodoro Timer",
          "Task Management",
          "Customizable Themes",
          "Statistics & History",
          "PWA / Offline Support"
        ],
        "screenshot": ogImageURL
      },
      {
        "@type": "WebSite",
        "@id": "https://pomodoro.manpuc.me/#website",
        "url": "https://pomodoro.manpuc.me",
        "name": siteName,
        "publisher": {
          "@id": "https://manpuc.me/#person"
        }
      }
    ]
  })}
/>
